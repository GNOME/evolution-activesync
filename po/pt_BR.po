#, c-format
msgid "wbxml is NULL!"
msgstr "wbxml é NULL!"

#: ../eas-daemon/libeas/eas-connection.c:1364
#, c-format
msgid "wbxml_len is 0!"
msgstr "wbxml_len é 0!"

