msgstr "Tipo de resposta HTTP não era WBXML"

#: ../eas-daemon/libeas/eas-connection.c:1323
#, c-format
msgid "HTTP response type was not MULTIPART"
msgstr "Tipo de resposta HTTP não era MULTIPART"

